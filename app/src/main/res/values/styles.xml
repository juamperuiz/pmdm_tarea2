<resources>

    <style name="SplashStyleWelcome" parent="">
        <item name="android:fontFamily">@font/dmsans_light</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">10pt</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="SplashStyleAppName" parent="">
        <item name="android:fontFamily">@font/dmsans_bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">8pt</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="SplashStyleAutor" parent="">
        <item name="android:fontFamily">@font/dmsans_light</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">6pt</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:alpha">0.5</item>
    </style>

    <style name="cardViewStyle" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:layout_height">100dp</item>
        <item name="android:layout_width">100dp</item>
        <item name="android:elevation">2dp</item>
    </style>

    <style name="Widget.Theme.PMDM_Tarea2.ActionBar.Fullscreen" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
    </style>

    <style name="Widget.Theme.PMDM_Tarea2.ButtonBar.Fullscreen" parent="">
        <item name="android:background">@color/black_overlay</item>
        <item name="android:buttonBarStyle">?android:attr/buttonBarStyle</item>
    </style>

    <style name="textoWelcome" parent="">
        <item name="android:textSize">14pt</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="textSplash" parent="">
        <item name="android:textSize">8pt</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

</resources>